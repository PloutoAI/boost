{
  "name": "plouto",
  "version": "0.2.0",
  "description": "Plouto's enforcement layer for Claude Code — applies workspace strategies (skill rollouts, model recommendations, MCP bans) on every SessionStart.",
  "author": {
    "name": "Plouto",
    "url": "https://plouto.ai"
  },
  "homepage": "https://github.com/PloutoAI/boost",
  "repository": "https://github.com/PloutoAI/boost",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "optimization",
    "audit",
    "skills",
    "mcp",
    "tokens"
  ],
  "commands": [
    "./commands/audit.md",
    "./commands/fix.md",
    "./commands/revert.md",
    "./commands/outcomes.md"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/boost.mjs plouto-sync",
            "timeout": 10,
            "async": true,
            "statusMessage": "Syncing workspace policies from Plouto…"
          }
        ]
      }
    ]
  }
}
