{
  "name": "charttui",
  "version": "0.1.0",
  "description": "Tiny, framework-agnostic terminal charts. Bar, stacked bar, progress, pie, donut, line, sparkline. Renders to ANSI strings or React components for Ink/opentui.",
  "keywords": [
    "tui",
    "terminal",
    "chart",
    "ansi",
    "bar",
    "pie",
    "donut",
    "line",
    "sparkline",
    "opentui",
    "ink"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./react": "./src/react/index.tsx",
    "./native": "./src/native/index.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "bun test"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "sixel": "^0.16.0"
  }
}
